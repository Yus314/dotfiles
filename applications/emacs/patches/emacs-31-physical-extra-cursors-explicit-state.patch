+;;; window-tests.el --- Tests for window.c  -*- lexical-binding: t; -*-
+
+;; Copyright (C) 2026 Free Software Foundation, Inc.
+
+;; This file is part of GNU Emacs.
+
+;;; Code:
+
+(require 'ert)
+
+(ert-deftest window-extra-cursors-storage-and-validation ()
+  (with-temp-buffer
+    (insert "abcdef")
+    (let ((window (selected-window)))
+      (set-window-buffer window (current-buffer))
+      (let ((marker (copy-marker 3)))
+        (should (equal (set-window-extra-cursors window (list 2 marker))
+                       (list 2 marker)))
+        (should (equal (window-extra-cursors window) (list 2 marker)))
+        (should-error (set-window-extra-cursors window '(0)))
+        (should-error (set-window-extra-cursors window '(8)))
+        (should-error (set-window-extra-cursors window '(2 . 3)))
+        (with-temp-buffer
+          (should-error
+           (set-window-extra-cursors window (list (copy-marker 1)))))
+        (set-marker marker nil)
+        ;; Dead markers remain queryable and are skipped safely by redisplay.
+        (redisplay t)
+        (should (eq (car (cdr (window-extra-cursors window))) marker))))))
+
+(ert-deftest window-extra-cursors-cleared-by-buffer-replacement ()
+  (let ((window (selected-window))
+        (original (window-buffer)))
+    (unwind-protect
+        (with-temp-buffer
+          (insert "abc")
+          (set-window-buffer window (current-buffer))
+          (set-window-extra-cursors window '(2))
+          (with-temp-buffer
+            (set-window-buffer window (current-buffer))
+            (should-not (window-extra-cursors window))))
+      (set-window-buffer window original))))
+
+(ert-deftest window-extra-cursors-survive-rejected-buffer-replacement ()
+  (let ((window (selected-window))
+        (original (window-buffer)))
+    (unwind-protect
+        (with-temp-buffer
+          (insert "abc")
+          (set-window-buffer window (current-buffer))
+          (set-window-extra-cursors window '(2))
+          (set-window-dedicated-p window t)
+          (with-temp-buffer
+            (should-error (set-window-buffer window (current-buffer)))
+            (should (equal (window-extra-cursors window) '(2)))))
+      (set-window-dedicated-p window nil)
+      (set-window-buffer window original))))
+
+(ert-deftest window-extra-cursors-use-explicit-render-state ()
+  (let ((xdisp (with-temp-buffer
+                 (insert-file-contents
+                  (expand-file-name "src/xdisp.c" source-directory))
+                 (buffer-string)))
+        (dispextern (with-temp-buffer
+                     (insert-file-contents
+                      (expand-file-name "src/dispextern.h" source-directory))
+                     (buffer-string))))
+    (should (string-match-p "struct window_cursor_state" dispextern))
+    (should (string-match-p "draw_window_cursor_state" xdisp))
+    (should (string-match-p "draw_glyphs_with_cursor_state" xdisp))
+    (should-not (string-match-p "static bool drawing_window_cursor_state"
+                                xdisp))
+    ;; A whole-window initializer is the scratch-copy technique this
+    ;; regression test exists to exclude, regardless of local variable name.
+    (should-not
+     (string-match-p
+      "struct[[:space:]]+window[[:space:]]+[^;=]+=[[:space:]]*\\*w"
+      xdisp))))
+
+(provide 'window-tests)
+;;; window-tests.el ends here
