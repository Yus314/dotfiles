+DEFUN ("window-extra-cursors", Fwindow_extra_cursors,
+       Swindow_extra_cursors, 0, 1, 0,
+       doc: /* Return the display-only extra cursor positions of WINDOW.
+WINDOW must be live and defaults to the selected window.  The returned list
+contains the same integer positions and markers supplied to
+`set-window-extra-cursors'.  */)
+  (Lisp_Object window)
+{
+  return decode_live_window (window)->extra_cursors;
+}
+
+DEFUN ("set-window-extra-cursors", Fset_window_extra_cursors,
+       Sset_window_extra_cursors, 2, 2, 0,
+       doc: /* Set WINDOW's display-only extra cursor positions to CURSORS.
+CURSORS must be a proper list of integer positions or live markers in the
+buffer displayed by WINDOW.  Integers must be within the buffer's accessible
+portion when installed.  Markers follow edits; integers do not.  A marker
+that later becomes dead or positions that later become inaccessible are
+silently skipped by redisplay.  Positions outside the visible portion of
+WINDOW are also skipped.
+
+Extra cursors are filled boxes on graphical displays.  They don't affect
+point, mark, command execution, scrolling, the system input caret, IME, or
+accessibility caret.  Text terminals don't display them.  Return CURSORS.  */)
+  (Lisp_Object window, Lisp_Object cursors)
+{
+  struct window *w = decode_live_window (window);
+  struct buffer *b = XBUFFER (w->contents);
+  Lisp_Object tail;
+  ptrdiff_t count = 0;
+
+  for (tail = cursors; CONSP (tail); tail = XCDR (tail))
+    {
+      Lisp_Object pos = XCAR (tail);
+      if (MARKERP (pos))
+        {
+          if (!XMARKER (pos)->buffer || XMARKER (pos)->buffer != b)
+            error ("Extra cursor marker is dead or belongs to another buffer");
+        }
+      else
+        {
+          CHECK_FIXNUM (pos);
+          if (XFIXNUM (pos) < BUF_BEGV (b) || XFIXNUM (pos) > BUF_ZV (b))
+            args_out_of_range (pos, w->contents);
+        }
+      count++;
+    }
+  CHECK_LIST_END (tail, cursors);
+
+#ifdef HAVE_WINDOW_SYSTEM
+  if (FRAME_WINDOW_P (XFRAME (w->frame)))
+    gui_clear_cursor (w);
+#endif
+  wset_extra_cursors (w, Fcopy_sequence (cursors));
+  wset_extra_phys_cursors (w, count ? make_vector (count * 8, make_fixnum (0)) : Qnil);
+  mark_window_display_accurate (window, false);
+  w->update_mode_line = true;
+  windows_or_buffers_changed = 31;
+  return cursors;
+}
