+/* Normalize *HPOS to the glyph actually used for a cursor at the horizontal
+   display boundary.  Return false if no glyph represents that position.  */
+static bool
+normalize_window_cursor_hpos (struct glyph_row *row, int *hpos)
+{
+  int used = row->used[TEXT_AREA];
+  if (used <= 0)
+    return false;
+  if (row->reversed_p)
+    {
+      if (*hpos < 0)
+	return false;
+      if (*hpos >= used)
+	*hpos = used - 1;
+    }
+  else
+    {
+      if (*hpos >= used)
+	return false;
+      if (*hpos < 0)
+	*hpos = 0;
+    }
+  return true;
+}
