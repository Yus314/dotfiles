+(defun window-extra-cursors-bench-log (text)
+  (write-region text nil "/tmp/window-extra-cursors-bench.log" t 'silent))
+(condition-case err
+    (progn
+      (window-extra-cursors-bench-log "benchmark-start\n")
+      (let ((window-extra-cursors-benchmark-output-file
+             "/tmp/window-extra-cursors-bench.log"))
