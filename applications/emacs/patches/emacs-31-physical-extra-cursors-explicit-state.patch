diff --git a/test/src/window-extra-cursors-bench.el b/test/src/window-extra-cursors-bench.el
new file mode 100644
index 0000000000000000000000000000000000000000..9be4d184c07b36192ffb069b3635826c6f62948e
--- /dev/null
+++ b/test/src/window-extra-cursors-bench.el
@@ -0,0 +1,38 @@
+;;; window-extra-cursors-bench.el --- Extra cursor redisplay benchmark -*- lexical-binding: t; -*-
+
+;; Copyright (C) 2026 Free Software Foundation, Inc.
+;; This file is part of GNU Emacs.
+
+;; Run in a graphical build, for example:
+;;   emacs -Q -l test/src/window-extra-cursors-bench.el
+
+(require 'benchmark)
+(require 'cl-lib)
+
+(defvar window-extra-cursors-benchmark-output-file nil)
+
+(defun window-extra-cursors-benchmark (&optional counts)
+  "Measure a forced redisplay for 10, 100, and 1000 extra cursors."
+  (interactive)
+  (with-temp-buffer
+    (dotimes (_ 2000) (insert "abcdefghij\n"))
+    (let ((window (selected-window)))
+      (set-window-buffer window (current-buffer))
+      (goto-char (point-min))
+      (redisplay t)
+      (dolist (count (or counts '(10 100 1000)))
+        (set-window-extra-cursors
+         window (cl-loop for i below count collect (1+ (* i 11))))
+        (let ((elapsed (car (benchmark-run 20 (redisplay t)))))
+          (let ((line (format "extra-cursors %4d: %.6fs\n" count elapsed)))
+            (message "%s" (string-trim-right line))
+            (when window-extra-cursors-benchmark-output-file
+              (write-region line nil
+                            window-extra-cursors-benchmark-output-file
+                            t 'silent))))))))
+
+(when noninteractive
+  (window-extra-cursors-benchmark))
+
+(provide 'window-extra-cursors-bench)
+;;; window-extra-cursors-bench.el ends here
diff --git a/test/src/window-extra-cursors-gui-smoke.el b/test/src/window-extra-cursors-gui-smoke.el
new file mode 100644
index 0000000000000000000000000000000000000000..6b4737009c1bfa5dc84f6185966f34403d99f40d
--- /dev/null
+++ b/test/src/window-extra-cursors-gui-smoke.el
@@ -0,0 +1,82 @@
+;;; window-extra-cursors-gui-smoke.el --- GUI smoke for extra cursors -*- lexical-binding: t; -*-
+
+;; Copyright (C) 2026 Free Software Foundation, Inc.
+;; This file is part of GNU Emacs.
+
+(require 'ert)
+
+(ert-deftest window-extra-cursors-gui-smoke ()
+  (skip-unless (display-graphic-p))
+  (with-temp-buffer
+    (insert "ordinary\nend\n01234567890123456789\nimage:X\n")
+    (let ((window (selected-window)))
+      (set-window-buffer window (current-buffer))
+      ;; Ordinary text and EOL.
+      (set-window-extra-cursors window '(2 9 13))
+      (redisplay t)
+      ;; A position hidden to the left by horizontal scrolling exercises the
+      ;; backend's margin-clamping path.
+      (set-window-hscroll window 5)
+      (set-window-extra-cursors window '(14 20))
+      (redisplay t)
+      (set-window-hscroll window 0)
+      ;; Exercise an image glyph when this build has XPM support.
+      (when (image-type-available-p 'xpm)
+        (goto-char (point-min))
+        (search-forward "X")
+        (put-text-property
+         (1- (point)) (point) 'display
+         '(image :type xpm :data
+                 "/* XPM */\nstatic char *x[]={\"2 2 2 1\",\". c red\",\"  c blue\",\". \",\" .\"};"))
+        (set-window-extra-cursors window (list (1- (point))))
+        (redisplay t))
+      (should (equal (window-extra-cursors window)
+                     (if (image-type-available-p 'xpm)
+                         (list (1- (point)))
+                       '(14 20)))))))
+
+(ert-deftest window-extra-cursors-gui-explicit-render-context ()
+  (skip-unless (display-graphic-p))
+  (with-temp-buffer
+    (insert "outside hover-zone\nraised glyph\nafter\n")
+    (let ((window (selected-window)))
+      (set-window-buffer window (current-buffer))
+      (goto-char (point-min))
+      (search-forward "hover-zone")
+      (let ((hover-start (match-beginning 0))
+            (hover-end (match-end 0))
+            (raised-start (save-excursion
+                            (goto-char (point-min))
+                            (forward-line 1)
+                            (point))))
+        (put-text-property hover-start hover-end 'mouse-face 'highlight)
+        ;; A raised glyph produces vertical overhang on ordinary GUI fonts,
+        ;; exercising erased-extra overlap repair when the cursor moves.
+        (put-text-property raised-start (1+ raised-start) 'raise 1.0)
+        (goto-char (point-max))
+        (redisplay t)
+        (when-let* ((posn (posn-at-point hover-start window))
+                    (xy (posn-x-y posn)))
+          (set-mouse-pixel-position
+           (window-frame window)
+           (+ (window-pixel-left window) (car xy))
+           (+ (window-pixel-top window) (cdr xy))))
+        (redisplay t)
+        ;; Primary point is outside the mouse face.  Simultaneously render one
+        ;; extra inside it, one outside it, and one on raised text; moving the
+        ;; set forces erase and overlap repair using each extra's rectangle.
+        (set-window-extra-cursors
+         window (list hover-start (1- hover-start) raised-start))
+        (redisplay t)
+        (set-window-extra-cursors
+         window (list (1+ hover-start) (1+ hover-end) (1+ raised-start)))
+        (redisplay t)
+        ;; Swap the two same-row locations so both an inside and an outside
+        ;; extra are erased while the row participates in mouse-face.
+        (set-window-extra-cursors
+         window (list (1- hover-start) hover-start raised-start))
+        (redisplay t)
+        (should (= 3 (length (window-extra-cursors window))))))))
+
+(let ((stats (ert-run-tests-batch t)))
+  (kill-emacs (if (zerop (ert-stats-completed-unexpected stats)) 0 1)))
